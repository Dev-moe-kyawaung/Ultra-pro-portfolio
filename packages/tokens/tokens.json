{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "version": "1.0.0",
  "meta": {
    "name": "Ultra Pro Portfolio Tokens",
    "brand": "Ultra Pro",
    "description": "Canonical design token source for Compose, Flutter, and React/Tailwind."
  },
  "color": {
    "brand": {
      "primary": { "value": "#6D5EF7" },
      "secondary": { "value": "#19D3DA" },
      "accent": { "value": "#FF4FD8" }
    },
    "neutral": {
      "0": { "value": "#FFFFFF" },
      "50": { "value": "#F8FAFC" },
      "100": { "value": "#F1F5F9" },
      "200": { "value": "#E2E8F0" },
      "700": { "value": "#334155" },
      "950": { "value": "#020617" }
    },
    "semantic": {
      "bg": {
        "canvas": { "value": "{color.neutral.0}" },
        "surface": { "value": "{color.neutral.50}" },
        "surfaceRaised": { "value": "{color.neutral.100}" }
      },
      "text": {
        "primary": { "value": "{color.neutral.950}" },
        "secondary": { "value": "{color.neutral.700}" },
        "inverse": { "value": "{color.neutral.0}" }
      },
      "accent": {
        "primary": { "value": "{color.brand.primary}" },
        "secondary": { "value": "{color.brand.secondary}" }
      },
      "border": {
        "default": { "value": "{color.neutral.200}" },
        "focus": { "value": "{color.brand.primary}" }
      }
    }
  },
  "typography": {
    "family": {
      "sans": { "value": "Inter" },
      "mono": { "value": "JetBrains Mono" }
    },
    "scale": {
      "display": { "size": { "value": 56 }, "lineHeight": { "value": 64 }, "weight": { "value": 700 } },
      "headline": { "size": { "value": 40 }, "lineHeight": { "value": 48 }, "weight": { "value": 700 } },
      "title": { "size": { "value": 28 }, "lineHeight": { "value": 36 }, "weight": { "value": 600 } },
      "body": { "size": { "value": 16 }, "lineHeight": { "value": 24 }, "weight": { "value": 400 } },
      "label": { "size": { "value": 14 }, "lineHeight": { "value": 20 }, "weight": { "value": 600 } }
    }
  },
  "space": {
    "0": { "value": 0 },
    "1": { "value": 4 },
    "2": { "value": 8 },
    "3": { "value": 12 },
    "4": { "value": 16 },
    "6": { "value": 24 },
    "8": { "value": 32 },
    "12": { "value": 48 },
    "16": { "value": 64 }
  },
  "radius": {
    "sm": { "value": 8 },
    "md": { "value": 12 },
    "lg": { "value": 20 },
    "xl": { "value": 28 },
    "pill": { "value": 9999 }
  }
}
